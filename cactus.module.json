{
  "name": "product-3d-views-for-shop",
  "version": "0.1.44",
  "tablePrefix": "p3d_",
  "description": "3D models for shop products and their variations: an auto-rotating thumbnail in the product gallery that opens a pan/tilt/zoom viewer in place of the main image.",
  "requiresCoreVersion": "0.5.490",
  "requiresModules": [
    { "name": "shop", "minVersion": "0.1.53" }
  ],
  "permissions": [],
  "requiredEnvVars": [],
  "cookieCategories": [],
  "extensionPoints": [
    { "point": "shop.product-editor-sections", "id": "product-3d-views-inline", "label": "3D views", "order": 60, "permission": "shop.products", "import": "./components/admin/Product3dSection", "component": "Product3dSection" },
    { "point": "shop.gallery-media", "id": "product-3d-views", "import": "./lib/gallery-provider", "component": "product3dGalleryProvider" },
    { "point": "shop-variations.variant-field-provider", "id": "product-3d-views-variant", "permission": "shop.products", "import": "./lib/variant-field-provider", "component": "product3dVariantFieldProvider" }
  ],
  "settingsTabs": [
    { "id": "product-3d-views", "label": "3D Viewer", "permission": "shop.manage", "host": "shop.settings-sub-tabs", "import": "./components/admin/Settings3dTab", "component": "Settings3dTab" }
  ],
  "teardown": [
    "p3d_models",
    "p3d_settings",
    "p3d_product_settings",
    "p3d_fabric_configs"
  ]
}
